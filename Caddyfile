{
	email {$CADDY_EMAIL:admin@example.com}

	# Issue #52 — edge per-IP rate-limit, shed at the proxy so a
	# volumetric flood never wakes up the Express loop.  Defined here
	# at the global level so the zone is reusable across handlers.
	# 300 events / 1 minute is ~3x the Express global limiter (100/min)
	# so legitimate concurrent users aren't hit at the edge; Express
	# remains the precise per-route gate.
	order rate_limit before reverse_proxy
}

{$CADDY_HOST:localhost} {
	# Defense-in-depth (#197): nginx + Express `compression` cover the
	# served paths today, but any future direct-serve from Caddy (static
	# asset CDN, custom error pages, redirect bodies) goes uncompressed
	# without this. Cheap, no-state-required, supports modern clients.
	encode gzip zstd

	# Structured access/error logs to stdout (captured by Docker logging
	# driver). JSON makes them ingestable by Loki/Promtail/Cloudwatch/etc.
	# Level INFO captures access logs and warnings; bump to DEBUG transiently
	# for incident response.
	log {
		output stdout
		format json
		level INFO
	}

	# API and uploads → backend
	# Issue #196 — Caddy defaults request_body max_size to 10MB, but
	# nginx.conf upstream allows 12MB and multer caps at 10MB.  Without
	# this directive a 10.5MB upload silently truncates at the edge and
	# the user sees a confusing "file too large" further downstream.
	# 12MB matches the nginx headroom; the inner multer limit still
	# enforces the per-file rule.
	handle /api/* {
		request_body {
			max_size 12MB
		}
		# Issue #52 — per-IP edge limit on the API surface.  Bursts of
		# 300+ req/min from a single client_ip are dropped with 429 at
		# the proxy.  The window is 1m so it self-resets quickly; abusers
		# don't get a sticky block, real users behind shared NAT get a
		# generous ceiling.  caddy-ratelimit module loaded via custom
		# build in ops/caddy/Dockerfile.
		rate_limit {
			zone api_per_ip {
				key {client_ip}
				events 300
				window 1m
			}
		}
		reverse_proxy server:5000
	}

	handle /uploads/* {
		request_body {
			max_size 12MB
		}
		reverse_proxy server:5000
	}

	handle /health {
		reverse_proxy server:5000
	}

	# Everything else → SPA frontend (nginx-unprivileged listens on 8080)
	handle {
		reverse_proxy client:8080
	}

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		# Issue #68 — helmet handles these on /api/* responses, but Caddy
		# serves the static client bundle directly and is the only header
		# source the browser sees for assets that never hit Express.
		Permissions-Policy "camera=(), microphone=(), payment=(), geolocation=(), interest-cohort=()"
		Cross-Origin-Opener-Policy "same-origin"
		Cross-Origin-Resource-Policy "same-site"
		# Issue #467 — CSP on every non-API response. Helmet's CSP only
		# fires on Express-handled paths (/api, /uploads); the SPA shell
		# is served from nginx → Caddy and was previously CSP-free.
		# Directives mirror helmet's server-side config for consistency.
		# frame-ancestors / base-uri / form-action close the
		# clickjacking + base-tag + form-hijack defense-in-depth gaps.
		Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self'; connect-src 'self' https://accounts.google.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
	}
}
