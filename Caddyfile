{
	email {$CADDY_EMAIL:admin@example.com}
}

{$CADDY_HOST:localhost} {
	# Defense-in-depth (#197): nginx + Express `compression` cover the
	# served paths today, but any future direct-serve from Caddy (static
	# asset CDN, custom error pages, redirect bodies) goes uncompressed
	# without this. Cheap, no-state-required, supports modern clients.
	encode gzip zstd

	# Structured access/error logs to stdout (captured by Docker logging
	# driver). JSON makes them ingestable by Loki/Promtail/Cloudwatch/etc.
	# Level INFO captures access logs and warnings; bump to DEBUG transiently
	# for incident response.
	log {
		output stdout
		format json
		level INFO
	}

	# API and uploads → backend
	# Issue #196 — Caddy defaults request_body max_size to 10MB, but
	# nginx.conf upstream allows 12MB and multer caps at 10MB.  Without
	# this directive a 10.5MB upload silently truncates at the edge and
	# the user sees a confusing "file too large" further downstream.
	# 12MB matches the nginx headroom; the inner multer limit still
	# enforces the per-file rule.
	handle /api/* {
		request_body {
			max_size 12MB
		}
		reverse_proxy server:5000
	}

	handle /uploads/* {
		request_body {
			max_size 12MB
		}
		reverse_proxy server:5000
	}

	handle /health {
		reverse_proxy server:5000
	}

	# Everything else → SPA frontend (nginx-unprivileged listens on 8080)
	handle {
		reverse_proxy client:8080
	}

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		# Issue #68 — helmet handles these on /api/* responses, but Caddy
		# serves the static client bundle directly and is the only header
		# source the browser sees for assets that never hit Express.
		Permissions-Policy "camera=(), microphone=(), payment=(), geolocation=(), interest-cohort=()"
		Cross-Origin-Opener-Policy "same-origin"
		Cross-Origin-Resource-Policy "same-site"
	}
}
