# Root environment file for Docker Compose
# Copy this to .env and fill in your values

# Required — Google Gemini API key for AI test generation
# Get your key at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# Server
PORT=5000
NODE_ENV=development
LOG_LEVEL=info
MONGO_URI=mongodb://localhost:27017/kiip_test_app

# Google OAuth — required for authentication
# Create credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# JWT — must be a long random secret in production
JWT_SECRET=your-jwt-secret-change-in-production

# Admin — the Google account email that receives admin role on first login
ADMIN_EMAIL=admin@example.com

# URLs
CLIENT_URL=http://localhost:5173
GOOGLE_CALLBACK_URL=/api/auth/google/callback

# Magic Link Email (optional — if not set, magic links are logged to console)
SMTP_USER=
SMTP_PASS=
SMTP_FROM=KIIP Study <your@gmail.com>

# Restrict OAuth/magic-link signup. CSV. Leave blank for open signup (default).
# ALLOWED_OAUTH_DOMAINS=example.com,company.com
# ALLOWED_EMAILS=alice@example.com,bob@example.com

# Auto-importer (issue #21) — opt in to run the additionalContext/tests
# auto-import on every server boot.  Default OFF: prod restarts don't
# re-classify Gemini files and don't burn API credits.  Set to "true"
# locally if you want the convenience.
ENABLE_AUTO_IMPORT=false

# Caddy reverse proxy / Let's Encrypt auto-HTTPS (production deploy)
# Public hostname Caddy serves — used as the site address in Caddyfile. e.g. kiip.example.com
CADDY_HOST=localhost
# Email registered with Let's Encrypt for auto-HTTPS certificate issuance
CADDY_EMAIL=admin@example.com
