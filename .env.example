# Root environment file for Docker Compose
# Copy this to .env and fill in your values

# Required — Google Gemini API key for AI test generation
# Get your key at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# Server
PORT=5000
NODE_ENV=development
LOG_LEVEL=info
MONGO_URI=mongodb://localhost:27017/kiip_test_app

# Mongo authentication (issue #465).
# REQUIRED for docker-compose: enables --auth so a compromised sibling
# container cannot pivot to the database. The values below are stamped
# into the mongo container on FIRST boot of an empty mongo_data volume.
# For an existing mongo_data volume you must add the user manually:
#   docker exec -it kiip-mongo mongosh
#   > use admin
#   > db.createUser({ user: 'kiip-root', pwd: '<strong-random>', roles: ['root'] })
MONGO_ROOT_USERNAME=kiip-root
MONGO_ROOT_PASSWORD=change-me-to-a-strong-random-string

# Google OAuth — required for authentication
# Create credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# JWT — must be a long random secret in production
JWT_SECRET=your-jwt-secret-change-in-production

# Issue #487 — optional second secret for cookie-parser HMAC layer
# (defense-in-depth on top of JWT signature). Falls back to JWT_SECRET
# when unset, so single-secret deployments still work; set this for a
# genuinely independent integrity check.
# COOKIE_SECRET=your-distinct-cookie-secret

# Admin — the Google account email that receives admin role on first login.
# Compared case-insensitively (#439); lowercase is preferred for clarity.
ADMIN_EMAIL=admin@example.com

# URLs
CLIENT_URL=http://localhost:5173
GOOGLE_CALLBACK_URL=/api/auth/google/callback

# Magic Link Email (optional — if not set, magic links are logged to console)
SMTP_USER=
SMTP_PASS=
SMTP_FROM=KIIP Study <your@gmail.com>
# Issue #474 — host/port/secure are configurable. Defaults match Gmail:
#   SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_SECURE=false (STARTTLS).
# For implicit TLS on 465 set SMTP_SECURE=true.
# SES / SendGrid / Postmark / Mailgun examples:
#   AWS SES:    SMTP_HOST=email-smtp.us-east-1.amazonaws.com SMTP_PORT=587 SMTP_SECURE=false
#   SendGrid:   SMTP_HOST=smtp.sendgrid.net                   SMTP_PORT=587 SMTP_SECURE=false
#   Postmark:   SMTP_HOST=smtp.postmarkapp.com                SMTP_PORT=587 SMTP_SECURE=false
#   Mailgun:    SMTP_HOST=smtp.mailgun.org                    SMTP_PORT=587 SMTP_SECURE=false
# SMTP_HOST=
# SMTP_PORT=
# SMTP_SECURE=

# Restrict OAuth/magic-link signup. CSV. Leave blank for open signup (default).
# ALLOWED_OAUTH_DOMAINS=example.com,company.com
# ALLOWED_EMAILS=alice@example.com,bob@example.com

# Auto-importer (issue #21) — opt in to run the additionalContext/tests
# auto-import on every server boot.  Default OFF: prod restarts don't
# re-classify Gemini files and don't burn API credits.  Set to "true"
# locally if you want the convenience.
ENABLE_AUTO_IMPORT=false

# Caddy reverse proxy / Let's Encrypt auto-HTTPS (production deploy)
# Public hostname Caddy serves — used as the site address in Caddyfile. e.g. kiip.example.com
CADDY_HOST=localhost
# Email registered with Let's Encrypt for auto-HTTPS certificate issuance
CADDY_EMAIL=admin@example.com
