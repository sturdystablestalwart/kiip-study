# Issue #206 — enforce the engines declared in each package.json so a
# local install on the wrong Node/npm version fails fast instead of
# producing silent dependency drift (CI uses Node 20).
engine-strict=true

# Fail `npm install` on advisories of high or critical severity.  Devs
# see the same audit gate CI would, before pushing.
audit-level=high

# Keep semver ranges (^/~) rather than save-exact: lockfile is the
# reproducibility contract; manifests stay flexible for minor bumps.
save-exact=false
