# API Configuration
# For local development: http://localhost:5000
# For Docker production: not needed (Dockerfile sets VITE_API_URL=/api at build time)
VITE_API_URL=http://localhost:5000

# AnyChart commercial license key (optional — removes watermark on Dashboard charts).
# Get one at https://www.anychart.com/buy/ (or Education/Non-profit license).
# Free/missing key = charts work fully but show the AnyChart logo watermark.
# Note: does NOT affect the rolldown "direct eval" build warning — that warning
# comes from anychart's minified bundle source and is benign (build-time scan only).
VITE_ANYCHART_LICENSE_KEY=
